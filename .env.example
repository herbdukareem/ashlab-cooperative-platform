APP_NAME="Ashlab Cooperative Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_NG

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cooperative
DB_USERNAME=cooperative
DB_PASSWORD=
DB_ROOT_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@ashlab.example
MAIL_FROM_NAME="Ashlab Cooperative Platform"
FILESYSTEM_DISK=local

PLATFORM_NAME="Ashlab Cooperative Platform"
TENANT_HEADER=X-Cooperative-ID
AUDIT_RETENTION_DAYS=2555
IDENTIFIER_HASH_KEY=

PLATFORM_ADMIN_FIRST_NAME=Platform
PLATFORM_ADMIN_LAST_NAME=Administrator
PLATFORM_ADMIN_EMAIL=admin@ashlab.example
PLATFORM_ADMIN_PASSWORD=
